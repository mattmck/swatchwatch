# Copy to terraform.dev.tfvars and fill in sensitive values.
subscription_id         = "your-azure-subscription-id"
environment             = "dev"
location                = "centralus"
github_repository       = "your-github-username/swatchwatch"
pg_admin_username       = "pgadmin"
pg_admin_password       = "<set-a-secure-password>"
create_openai_resources = true
# openai_batch_deployment_name = "hex-detector-batch"

# Optional batch-hex detection toggles
# hex_detection_batch_enabled      = true
# hex_detection_batch_min_images   = 5
# ingestion_ai_batch_poll_schedule = "0 */2 * * * *"
# ingestion_ai_batch_max_poll_jobs = 10
